import random


def generer_tirage():
    return random.sample(range(1, 50), 10)


def saisir_numeros():
    choix_utilisateur = []
    while len(choix_utilisateur) < 10:
        try:
            entree = input(f"Entrez le numéro {len(choix_utilisateur) + 1} : ")
            nombre = int(entree)
            if nombre < 1 or nombre > 49:
                print("Erreur : Entre 1 et 49.")
            elif nombre in choix_utilisateur:
                print("Erreur : Déjà saisi.")
            else:
                choix_utilisateur.append(nombre)
        except ValueError:
            print("Erreur : Entrez un nombre valide.")
    return choix_utilisateur


def calculer_resultats(tirage, utilisateur):
    gagnants = [n for n in utilisateur if n in tirage]
    nb_bon_ordre = 0
    for i in range(10):
        if utilisateur[i] == tirage[i]:
            nb_bon_ordre += 1
    return gagnants, nb_bon_ordre


def determiner_recompense(nb_gagnants, nb_ordre):
    if nb_gagnants == 10:
        base = "GRAND PRIX : 1 000 000 €"
    elif nb_gagnants >= 7:
        base = "Prix Argent : 10 000 €"
    elif nb_gagnants >= 4:
        base = "Prix Bronze : 100 €"
    elif nb_gagnants >= 1:
        base = "Petit lot : 2 €"
    else:
        base = "Perdu"

    if nb_ordre > 0:
        base += f" (+ Bonus ordre: {nb_ordre})"
    return base


def main():
    tirage_ordinateur = generer_tirage()
    mes_numeros = saisir_numeros()
    liste_gagnants, bonus_ordre = calculer_resultats(tirage_ordinateur, mes_numeros)

    print(f"\nTirage : {tirage_ordinateur}")
    print(f"Vos numéros : {mes_numeros}")
    print(f"Gagnants : {len(liste_gagnants)}")

    gain = determiner_recompense(len(liste_gagnants), bonus_ordre)
    print(f"Récompense : {gain}")


if __name__ == "_main_":
    main()
